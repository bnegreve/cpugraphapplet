#!/usr/bin/env python3
"""Waybar custom module: 16-sample sparkline of CPU usage.

Modes:
  avg  average usage across all cores (default)
  max  usage of the single most-loaded core
"""

import argparse
import json
import os
import tempfile
import time
from pathlib import Path

BLOCKS = "▁▂▃▄▅▆▇█"
HISTORY_LEN = 16
HZ = os.sysconf(os.sysconf_names["SC_CLK_TCK"])


def state_path(mode: str) -> Path:
    # Separate state per mode so two waybar modules (avg + max) can run in
    # parallel without clobbering each other's history.
    base = os.environ.get("XDG_RUNTIME_DIR") or "/tmp"
    return Path(base) / f"cpugraphapplet.{mode}.state"


def read_per_cpu_totals() -> list[tuple[int, int]]:
    """Return [(total, idle), ...] per core, skipping the aggregate 'cpu' line.

    /proc/stat cpuN line: user nice system idle iowait irq softirq steal guest guest_nice
    user already includes guest, nice already includes guest_nice — sum only the first 8.
    """
    cores: list[tuple[int, int]] = []
    with open("/proc/stat") as f:
        for line in f:
            if not line.startswith("cpu"):
                break
            name, *rest = line.split()
            if name == "cpu":
                continue
            values = [int(x) for x in rest[:8]]
            idle = values[3] + values[4]
            total = sum(values)
            cores.append((total, idle))
    return cores


def debug_log(msg: str) -> None:
    """Append a timestamped line to a debug log next to the state files.

    Enabled unconditionally so we can diagnose spurious history resets. Only
    fires on unusual code paths, so the log stays small.
    """
    base = os.environ.get("XDG_RUNTIME_DIR") or "/tmp"
    try:
        with open(Path(base) / "cpugraphapplet.log", "a") as f:
            f.write(f"{time.time():.3f} pid={os.getpid()} {msg}\n")
    except OSError:
        pass


def load_state(mode: str) -> dict:
    p = state_path(mode)
    try:
        return json.loads(p.read_text())
    except FileNotFoundError:
        return {"prev_cores": None, "history": []}
    except (json.JSONDecodeError, OSError) as e:
        debug_log(f"load_state({mode}) failed ({type(e).__name__}: {e}); defaulting")
        return {"prev_cores": None, "history": []}


def save_state(mode: str, state: dict) -> None:
    # Write via a UNIQUE temp file per process + atomic rename. If two
    # invocations overlap (waybar spawns a second one before the first
    # finishes), a shared temp filename would have interleaved write()
    # syscalls producing corrupt JSON — the next load would then hit
    # JSONDecodeError, fall back to defaults, and blank the graph.
    # mkstemp guarantees a unique name; os.replace is atomic.
    p = state_path(mode)
    fd, tmp_name = tempfile.mkstemp(prefix=p.name + ".", suffix=".tmp", dir=str(p.parent))
    tmp = Path(tmp_name)
    try:
        with os.fdopen(fd, "w") as f:
            f.write(json.dumps(state))
        os.replace(tmp, p)
    except BaseException:
        try:
            tmp.unlink()
        except OSError:
            pass
        raise


def sparkline(history: list[float]) -> str:
    # Left-pad so the graph is always HISTORY_LEN wide and grows from the
    # right on first runs. NBSP (U+00A0) instead of regular space because
    # Pango collapses runs of ASCII whitespace in waybar labels.
    padded: list[float | None] = [None] * (HISTORY_LEN - len(history)) + list(history)
    out = []
    for v in padded:
        if v is None:
            out.append(" ")
        else:
            idx = min(len(BLOCKS) - 1, int(v / 100 * len(BLOCKS)))
            out.append(BLOCKS[idx])
    return "".join(out)


def classify(pct: float) -> str:
    if pct < 25:
        return "low"
    if pct < 60:
        return "medium"
    if pct < 85:
        return "high"
    return "critical"


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument(
        "--mode",
        choices=("avg", "max"),
        default="avg",
        help="avg = average across all cores (default); max = most-loaded core",
    )
    args = parser.parse_args()

    cores = read_per_cpu_totals()
    now_wall = time.monotonic()
    state = load_state(args.mode)

    prev_cores = state.get("prev_cores")
    prev_wall = state.get("prev_wall")
    history: list[float] = state.get("history", [])
    # On core count change (CPU hotplug) skip the delta this tick, but keep
    # the history — a hotplug event shouldn't blank the graph.
    if prev_cores is not None and len(prev_cores) != len(cores):
        debug_log(f"core count changed: {len(prev_cores)} -> {len(cores)}; skipping delta")
        prev_cores = None

    # Normalize by wall time × HZ, not by per-core jiffy delta. On NO_HZ
    # kernels an idle core barely accumulates ticks, so busy/total spuriously
    # spikes to ~100% on a single stray jiffy. busy/(HZ·wall_seconds) gives
    # "fraction of the core actually spent working", which is stable.
    if prev_cores is not None and prev_wall is not None:
        dt_wall = now_wall - prev_wall
        if dt_wall >= 0.1:
            denom = HZ * dt_wall
            per_core_pct: list[float] = []
            for (total, idle), (pt, pi) in zip(cores, prev_cores):
                busy = (total - pt) - (idle - pi)
                per_core_pct.append(max(0.0, min(100.0, 100.0 * busy / denom)))
            pct = max(per_core_pct) if args.mode == "max" else sum(per_core_pct) / len(per_core_pct)
            history.append(round(pct, 1))
            history = history[-HISTORY_LEN:]

    save_state(args.mode, {"prev_cores": cores, "prev_wall": now_wall, "history": history})

    current = history[-1] if history else 0.0
    label = "max core" if args.mode == "max" else "avg of all cores"
    output = {
        "text": sparkline(history),
        "tooltip": f"CPU: {current:.1f}%  ({label}, last {len(history)}s)",
        "class": classify(current),
        "percentage": int(current),
    }
    print(json.dumps(output))


if __name__ == "__main__":
    main()
